{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksConfig": {
      "nodeVersion": "20"
    }
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "cd backend && npm install && node src/server.js",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
